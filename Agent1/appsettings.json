{
  "Llm": {
    "ModelId": "deepseek-r1:local7b",
    "Endpoint": "http://localhost:11434",
    "MultimodalModelId": "qwen-vl:latest",
    "MaxRetries": 3,
    "RetryDelayMs": 1000,
    "BufferFlushThreshold": 50
  },
  "KnowledgeBase": {
    "BasePath": "d:\\桌面\\agent\\项目\\Agent1\\knowledgebase",
    "Sources": [
      { "Name": "国标", "Path": "国标", "Priority": 100 },
      { "Name": "园区规则", "Path": "园区规则", "Priority": 80 },
      { "Name": "历史案例", "Path": "历史案例", "Priority": 60 }
    ],
    "ChunkSize": 500,
    "SearchMode": "Hybrid"
  },
  "VectorSearch": {
    "EnableVectorSearch": true,
    "EmbeddingModelId": "nomic-embed-text:latest",
    "EmbeddingDimension": 768,
    "Bm25Weight": 0.4,
    "VectorWeight": 0.6,
    "IndexType": "hnsw",
    "HnswM": 16,
    "HnswEfConstruction": 200,
    "HnswEfSearch": 64
  },
  "Database": {
    "Provider": "PostgreSQL",
    "Host": "localhost",
    "Port": 5432,
    "DatabaseName": "chemical_park_ai_agent",
    "Username": "postgres",
    "Password": "",
    "ConnectionTimeout": 30,
    "MaxPoolSize": 20
  },
  "Integration": {
    "EnableERPSync": false,
    "EnableWMSSync": false,
    "EnableEHSSync": false,
    "ERPApiBaseUrl": "",
    "WMSApiBaseUrl": "",
    "EHSApiBaseUrl": ""
  },
  "ChemicalTool": {
    "Tools": [
      { "Name": "CheckHazardCategory",   "Description": "查询危化品危险类别及适用国标",   "KeywordTriggers": ["类别", "分类", "属于", "国标", "GB"] },
      { "Name": "CheckStorageCompatibility", "Description": "检查两种危化品是否可同库储存", "KeywordTriggers": ["同库", "共存", "混合", "禁忌", "配伍", "储存冲突"] },
      { "Name": "GetSafetyDistance",      "Description": "查询设施间安全间距要求",        "KeywordTriggers": ["安全距离", "间距", "消防通道", "储罐间距", "防火间距"] },
      { "Name": "GetCurrentTime",         "Description": "获取当前时间",                   "KeywordTriggers": ["时间", "几点", "日期"] },
      { "Name": "Calculate",              "Description": "数学计算",                       "KeywordTriggers": ["计算", "等于"] }
    ]
  },
  "Audit": {
    "EnableOperationLog": true,
    "AuditLogRetentionDays": 180,
    "EnableDataEncryption": true
  }
}
