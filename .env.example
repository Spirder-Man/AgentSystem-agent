# ==========================================
# AgentSystem - 环境变量配置模板
# 使用方式：复制为 .env 后填入真实值
#   cp .env.example .env
# ==========================================

# PostgreSQL 数据库连接（必填）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chemical_park_ai_agent
DB_USERNAME=postgres
DB_PASSWORD=你的数据库密码

# 以下配置在 appsettings.json 中已有默认值，
# 如需覆盖可通过环境变量设置（取消注释并填入值即可）
# LLM_ENDPOINT=http://localhost:11434
# LLM_MODEL_ID=deepseek-r1:local7b
